# Production Socket.IO URL
# Replace with your actual backend URL when deploying

# Railway example:
# VITE_SOCKET_URL=https://your-app.up.railway.app

# Render example:
# VITE_SOCKET_URL=https://your-app.onrender.com

# Heroku example:
# VITE_SOCKET_URL=https://your-app.herokuapp.com

# For local development, keep this commented or use localhost
# VITE_SOCKET_URL=http://localhost:5000
